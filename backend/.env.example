# Backend environment template — copy to backend/.env and fill real values
# (or pass via --env-file at `docker run`). NEVER commit real keys.

PORT=8787
LOG_LEVEL=info

# Primary LLM (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# Fallback LLM (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Reasoning / latency controls
LLM_TIMEOUT_SECONDS=12
REQUEST_BUDGET_SECONDS=25
USE_LLM=true
