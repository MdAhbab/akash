# Template for the judge's private env file (Docker submission path).
# Copy to judging.env, fill REAL values and pass with --env-file. Never commit.
#
#   docker run -p 8000:8000 -e PORT=8000 --env-file judging.env akash-api
#
# Note: the service runs WITHOUT keys too (deterministic mode) - it stays fully
# functional and schema-correct; LLM phrasing is simply skipped.

PORT=8000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
LLM_TIMEOUT_SECONDS=6
USE_LLM=true
