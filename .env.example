# ════════════════════════════════════════════════════════════════════════
#  QueueStorm Investigator — environment template
#  Copy this file to `.env` (gitignored) and fill in REAL values there.
#  NEVER commit a file with real keys. Only this *.example is committed.
# ════════════════════════════════════════════════════════════════════════

# ─── Service ─────────────────────────────────────────────────────────────
PORT=8787
LOG_LEVEL=info

# ─── Primary LLM: Google Gemini ──────────────────────────────────────────
# Key from Google AI Studio / Gemini API.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# ─── Fallback LLM: OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ─── Reasoning / latency controls ────────────────────────────────────────
# Hard per-request budget for the whole analyze pipeline (seconds).
# The judge harness hard-times-out at 30s; we cut LLM calls well before that.
LLM_TIMEOUT_SECONDS=12
REQUEST_BUDGET_SECONDS=25
# Set to "false" to run a pure deterministic (no-LLM) mode for max speed/zero cost.
USE_LLM=true

# ─── Optional MySQL durability mirror ────────────────────────────────────
# DB_BACKEND=memory (default) keeps everything in-memory. Set to "mysql" to also
# persist analyzed tickets. The DB is NEVER in the request path — if it is down,
# the API keeps working. The docker-compose / VM deploy set these for you.
DB_BACKEND=memory
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=queuestorm
MYSQL_PASSWORD=
MYSQL_DB=queuestorm
